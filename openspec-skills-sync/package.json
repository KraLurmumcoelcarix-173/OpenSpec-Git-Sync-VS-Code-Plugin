{
  "displayName": "OpenSpec Skills Sync",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opensync-sidebar",
          "title": "OpenSpec Skills Sync",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "opensync-sidebar": [
        {
          "id": "opensync.panel",
          "name": "Sync Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "opensync.pull",
        "title": "OpenSpec: Pull Latest Skills"
      },
      {
        "command": "opensync.refresh",
        "title": "OpenSpec: Refresh Status"
      },
      {
        "command": "opensync.setupGit",
        "title": "OpenSpec: Configure Git Identity & Credential"
      }
    ],
    "configuration": {
      "title": "OpenSpec Skills Sync",
      "properties": {
        "opensync.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en"
          ],
          "default": "zh-CN",
          "description": "界面语言 / UI language"
        },
        "opensync.syncBranch": {
          "type": "string",
          "default": "main",
          "description": "同步来源分支 / Branch to sync skills from"
        }
      }
    }
  },
  "name": "openspec-skills-sync",
  "version": "0.1.0",
  "description": "",
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.125.0",
    "jest": "^30.4.2",
    "sharp": "^0.35.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
