{
  "name": "openspec-skills-sync",
  "displayName": "OpenSpec Skills Sync",
  "description": "一键同步 OpenSpec skills 文档的 VS Code 插件，面向非开发者",
  "version": "0.1.0",
  "publisher": "AI-Coding-Group",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/KraLurmumcoelcarix-173/OpenSpec-Git-Sync-VS-Code-Plugin.git"
  },
  "engines": { "vscode": "^1.80.0" },
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opensync-sidebar",
          "title": "OpenSpec Skills Sync",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "opensync-sidebar": [
        { "id": "opensync.panel", "name": "Sync Panel" }
      ]
    },
    "commands": [
      { "command": "opensync.pull", "title": "OpenSpec: Pull Latest Skills" },
      { "command": "opensync.refresh", "title": "OpenSpec: Refresh Status" },
      { "command": "opensync.setupGit", "title": "OpenSpec: Configure Git Identity & Credential" }
    ],
    "configuration": {
      "title": "OpenSpec Skills Sync",
      "properties": {
        "opensync.language": {
          "type": "string",
          "enum": ["zh-CN", "en"],
          "default": "zh-CN",
          "description": "界面语言 / UI language"
        },
        "opensync.syncBranch": {
          "type": "string",
          "default": "main",
          "description": "同步来源分支 / Branch to sync skills from"
        }
      }
    }
  },
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.125.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}